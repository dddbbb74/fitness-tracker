<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="FitTrack">
    <meta name="theme-color" content="#0f172a">
    <title>FitTrack</title>

    <link rel="manifest" href="manifest.json">
    <link rel="apple-touch-icon" href="icons/icon-192.png">
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <div id="app">
        <!-- Header -->
        <header id="app-header">
            <h1 id="page-title">Workouts</h1>
            <button id="header-action-btn" class="header-btn" style="display:none;">+</button>
        </header>

        <!-- Pages -->
        <main id="main-content">
            <!-- Workouts Page -->
            <div id="page-workouts" class="page active">
                <div id="workouts-empty" class="empty-state">
                    <div class="empty-icon">🏋️</div>
                    <h2>No Workouts Yet</h2>
                    <p>Tap the + button to log your first workout.</p>
                </div>
                <div id="workouts-list" class="list-container"></div>
            </div>

            <!-- Body Weight Page -->
            <div id="page-bodyweight" class="page">
                <div id="bodyweight-empty" class="empty-state">
                    <div class="empty-icon">⚖️</div>
                    <h2>No Weight Entries</h2>
                    <p>Start tracking your body weight.</p>
                </div>
                <div id="bodyweight-content">
                    <canvas id="bodyweight-chart" class="chart-canvas"></canvas>
                    <div id="bodyweight-stats" class="stats-row"></div>
                    <div id="bodyweight-list" class="list-container"></div>
                </div>
            </div>

            <!-- Progress Page -->
            <div id="page-progress" class="page">
                <div id="progress-empty" class="empty-state">
                    <div class="empty-icon">📊</div>
                    <h2>Not Enough Data</h2>
                    <p>Log some workouts and weigh-ins to see your progress.</p>
                </div>
                <div id="progress-content">
                    <div class="time-range-picker" id="time-range-picker">
                        <button class="range-btn active" data-range="7">Week</button>
                        <button class="range-btn" data-range="30">Month</button>
                        <button class="range-btn" data-range="90">3 Mo</button>
                        <button class="range-btn" data-range="365">Year</button>
                        <button class="range-btn" data-range="0">All</button>
                    </div>
                    <div id="progress-overview" class="stats-row"></div>
                    <div class="section-card">
                        <h3>Weekly Volume (lbs)</h3>
                        <canvas id="volume-chart" class="chart-canvas"></canvas>
                    </div>
                    <div class="section-card">
                        <h3>Body Weight Trend</h3>
                        <canvas id="progress-bw-chart" class="chart-canvas"></canvas>
                    </div>
                    <div class="section-card">
                        <h3>Personal Records 🏆</h3>
                        <div id="pr-list" class="list-container"></div>
                    </div>
                    <div class="section-card">
                        <h3>Workout Frequency</h3>
                        <canvas id="frequency-chart" class="chart-canvas"></canvas>
                    </div>
                </div>
            </div>
        </main>

        <!-- Tab Bar -->
        <nav id="tab-bar">
            <button class="tab active" data-page="workouts">
                <span class="tab-icon">🏋️</span>
                <span class="tab-label">Workouts</span>
            </button>
            <button class="tab" data-page="bodyweight">
                <span class="tab-icon">⚖️</span>
                <span class="tab-label">Weight</span>
            </button>
            <button class="tab" data-page="progress">
                <span class="tab-icon">📊</span>
                <span class="tab-label">Progress</span>
            </button>
        </nav>
    </div>

    <!-- Modals -->
    <!-- Add Workout Modal -->
    <div id="modal-add-workout" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <button class="modal-cancel" onclick="closeModal('modal-add-workout')">Cancel</button>
                <h2>New Workout</h2>
                <button class="modal-save" id="save-workout-btn">Create</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Workout Name</label>
                    <input type="text" id="workout-name" placeholder="e.g., Push Day">
                </div>
                <div class="form-group">
                    <label>Date</label>
                    <input type="datetime-local" id="workout-date">
                </div>
                <div class="form-group">
                    <label>Notes (optional)</label>
                    <textarea id="workout-notes" placeholder="How did it go?" rows="2"></textarea>
                </div>
                <div class="form-group">
                    <label>Quick Select</label>
                    <div class="chip-row" id="workout-presets"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Workout Detail Modal -->
    <div id="modal-workout-detail" class="modal">
        <div class="modal-content modal-full">
            <div class="modal-header">
                <button class="modal-cancel" onclick="closeModal('modal-workout-detail')">← Back</button>
                <h2 id="detail-workout-name">Workout</h2>
                <button class="modal-save" id="add-exercise-btn">+ Exercise</button>
            </div>
            <div class="modal-body" id="workout-detail-body">
                <div id="detail-summary" class="stats-row"></div>
                <div id="detail-notes" class="detail-notes"></div>
                <div id="detail-exercises"></div>
            </div>
        </div>
    </div>

    <!-- Add Exercise Modal -->
    <div id="modal-add-exercise" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <button class="modal-cancel" onclick="closeModal('modal-add-exercise')">Cancel</button>
                <h2>Add Exercise</h2>
                <button class="modal-save" id="save-exercise-btn">Add</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Exercise Name</label>
                    <input type="text" id="exercise-name" placeholder="e.g., Bench Press">
                </div>
                <div class="form-group">
                    <label>Search Common Exercises</label>
                    <input type="text" id="exercise-search" placeholder="Search...">
                    <div id="exercise-suggestions" class="suggestions-list"></div>
                </div>
                <div class="form-group">
                    <label>Sets</label>
                    <div class="stepper">
                        <button onclick="adjustStepper('exercise-sets', -1)">−</button>
                        <input type="number" id="exercise-sets" value="3" min="1" max="20">
                        <button onclick="adjustStepper('exercise-sets', 1)">+</button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Default Reps</label>
                    <div class="stepper">
                        <button onclick="adjustStepper('exercise-reps', -1)">−</button>
                        <input type="number" id="exercise-reps" value="10" min="1" max="100">
                        <button onclick="adjustStepper('exercise-reps', 1)">+</button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Default Weight (lbs)</label>
                    <input type="number" id="exercise-weight" value="0" min="0" step="2.5">
                </div>
            </div>
        </div>
    </div>

    <!-- Add Body Weight Modal -->
    <div id="modal-add-bodyweight" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <button class="modal-cancel" onclick="closeModal('modal-add-bodyweight')">Cancel</button>
                <h2>Log Weight</h2>
                <button class="modal-save" id="save-bodyweight-btn">Save</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Weight (lbs)</label>
                    <input type="number" id="bw-weight" value="150" min="50" max="500" step="0.1">
                    <div class="quick-adjust">
                        <button class="adjust-btn green" onclick="adjustWeight(-1)">−1</button>
                        <button class="adjust-btn green" onclick="adjustWeight(-0.5)">−0.5</button>
                        <button class="adjust-btn red" onclick="adjustWeight(0.5)">+0.5</button>
                        <button class="adjust-btn red" onclick="adjustWeight(1)">+1</button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Date</label>
                    <input type="date" id="bw-date">
                </div>
                <div class="form-group">
                    <label>Notes (optional)</label>
                    <textarea id="bw-notes" placeholder="e.g., After breakfast" rows="2"></textarea>
                </div>
            </div>
        </div>
    </div>

    <script src="js/db.js"></script>
    <script src="js/charts.js"></script>
    <script src="js/workouts.js"></script>
    <script src="js/bodyweight.js"></script>
    <script src="js/progress.js"></script>
    <script src="js/app.js"></script>
</body>
</html>
